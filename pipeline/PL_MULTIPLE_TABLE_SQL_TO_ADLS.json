{
	"name": "PL_MULTIPLE_TABLE_SQL_TO_ADLS",
	"properties": {
		"activities": [
			{
				"name": "Tablelookup",
				"type": "Lookup",
				"dependsOn": [],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
